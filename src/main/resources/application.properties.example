##############################################################################
# application.properties.example
#
# Copy this file to src/main/resources/application.properties
# and fill in the values for your local environment.
# The real application.properties is gitignored — never commit secrets.
##############################################################################

spring.application.name=contact-management-system

# SQL Server connection — update host, port, and database name as needed
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=contact_db;encrypt=false;trustServerCertificate=true
spring.datasource.username=${DB_USERNAME:cms_user}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=com.microsoft.sqlserver.jdbc.SQLServerDriver
spring.jpa.database-platform=org.hibernate.dialect.SQLServerDialect

spring.jpa.hibernate.ddl-auto=update
spring.jpa.open-in-view=false
spring.jpa.show-sql=false

spring.jpa.properties.hibernate.format_sql=true

server.port=8080

# JWT — use a long random string (min 32 chars) in production
jwt.secret=${JWT_SECRET}
jwt.expiration=86400000

cors.allowed-origins=http://localhost:5173,http://127.0.0.1:5173

logging.level.com.cms=INFO
logging.level.org.springframework.security=WARN
